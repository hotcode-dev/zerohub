{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "strict": true,
        "noImplicitAny": true,
        "exactOptionalPropertyTypes": true,
        "noPropertyAccessFromIndexSignature": true,
        "allowJs": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["@types/node", "playwright"]
    },
    "include": [
        "tests/**/*.ts",
        "harness/**/*.ts",
        "scripts/**/*.mjs"
    ]
}